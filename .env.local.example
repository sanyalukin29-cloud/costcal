# ============================================
# CostCal — Environment Variables Template
# ============================================
# Copy to .env.local and fill in real values.
# Never commit .env.local to git.

# --- Supabase (Day 1 — required for email capture & auth) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Resend (Phase 1 — transactional email) ---
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=noreply@costcal.app

# --- GBPrimePay (Phase 1 — payments) ---
GBPRIMEPAY_API_KEY=
GBPRIMEPAY_SECRET=
GBPRIMEPAY_WEBHOOK_SECRET=

# --- Admin ---
ADMIN_EMAILS=sanyaluk.in29@gmail.com

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://costcal.app
